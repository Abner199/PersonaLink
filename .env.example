# ============================================================
# Netlify Functions 后端环境变量
# 在 Netlify Dashboard > Site Settings > Environment Variables 中设置
# ============================================================

# Supabase项目URL（在Supabase Dashboard > Settings > API中找到）
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key（有完整权限，切勿暴露在前端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# 前端构建环境变量
# GitHub Pages部署时作为GitHub Actions Secrets/Variables设置
# ============================================================

# 后端API地址（GitHub Pages使用Netlify作为后端时设置）
# 格式：https://your-netlify-site.netlify.app/api
VITE_API_URL=

# 前端路由基础路径（若部署在子目录则需设置，如 /PersonaLink/）
VITE_BASE_URL=/
